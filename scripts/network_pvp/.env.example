# OS-GO Network Server Configuration
# Copy this file to .env and adjust values

# Server settings
WS_HOST=0.0.0.0
WS_PORT=8765
MAX_ROOMS=100
MAX_ROOM_AGE=60
JWT_SECRET=your-super-secret-key-here
LOG_LEVEL=info
ENABLE_CORS=true

# Client settings (for client-side .env)
# WS_SERVER_URL=ws://localhost:8765/ws
# WS_USERNAME=Player
# WS_AUTO_RECONNECT=true
# WS_RECONNECT_DELAY=5
# WS_MAX_RECONNECT=3
# WS_SAVE_DIR=./games/pvp/
