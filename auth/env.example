# .env.example — шаблон для команды
# Скопируй в .env и заполни реальными значениями

# ==========================================
# БЕЗОПАСНОСТЬ (обязательно поменять!)
# ==========================================
SECRET_KEY=change-this-to-random-32-chars-string
JWT_SECRET=another-random-secret-min-32-characters
ENCRYPTION_KEY=base64-encoded-32-byte-key-for-aes

# ==========================================
# БАЗА ДАННЫХ
# ==========================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname


# ==========================================
# AUTH0 (опционально)
# ==========================================
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://your-api.example.com
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ==========================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ==========================================
DEBUG=true
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Argon2 (не менять без причины)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ==========================================
# EMAIL / SMTP
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_USE_TLS=true

# Верификация
VERIFICATION_TOKEN_EXPIRE_HOURS=24
APP_URL=http://localhost:8000